# ── Required ───────────────────────────────────────────────────────────────────
# Private key of the wallet that will sign / send transactions.
# Use a test wallet — never a high-value hot wallet.
PRIVATE_KEY=0x...

# ── Strongly recommended ────────────────────────────────────────────────────────
# Block when you FIRST shielded tokens (or any recent block to limit scan window).
# Setting this to a recent block (e.g. 437000000 for Arbitrum) makes the
# merkle tree sync take minutes instead of hours.
# Leave blank to use the SDK's deployment block (56M for Arbitrum → very slow).
CREATION_BLOCK=

# Your existing RAILGUN wallet ID from browser localStorage.
# Open DevTools → Application → Local Storage → "incogpay-railgun-wallet-id"
# Paste the value here to reuse the same wallet instead of deriving a new one.
# Leave blank to auto-derive from PRIVATE_KEY.
WALLET_ID=

# ── Optional — defaults shown ─────────────────────────────────────────────────
# EVM RPC endpoint. Public Arbitrum fallback — use Alchemy/Infura for reliability.
RPC_URL=https://arb1.arbitrum.io/rpc

# Chain ID: 42161=Arbitrum, 1=Ethereum, 137=Polygon, 56=BNB
CHAIN_ID=42161

# ERC-20 token address. Default: USDC on Arbitrum.
TOKEN_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# Token decimals (USDC=6, most others=18)
TOKEN_DECIMALS=6

# Amount to send in human-readable units (e.g. "0.5" = 0.5 USDC)
SEND_AMOUNT=0.01

# Recipient public address (0x…) or RAILGUN 0zk address.
# Leave blank to skip the send step and only run balance check + shield dry-run.
RECIPIENT=
